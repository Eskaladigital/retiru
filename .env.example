# RETIRU — Variables de entorno
# Copia este archivo a .env.local y rellena los valores

NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Opcional: URI de Postgres (Settings → Database en Supabase). Solo para scripts locales que ejecutan SQL (p. ej. scripts/run-sql-migration.mjs). No la subas a git.
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_pk
STRIPE_SECRET_KEY=your_stripe_sk
STRIPE_WEBHOOK_SECRET=your_stripe_wh_secret

RESEND_API_KEY=your_resend_key
RESEND_FROM_EMAIL=hola@retiru.com

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Retiru

# OpenAI (opcional): centros, blog, traducciones y portadas de eventos con GPT Image 1.5
OPENAI_API_KEY=

# TinyMCE (opcional): editor de descripción de retiros en el dashboard.
# Obtén una clave en https://www.tiny.cloud/ y registra el dominio de producción.
# Si está vacío, se usa «no-api-key» (aviso en consola; adecuado solo para desarrollo).
NEXT_PUBLIC_TINYMCE_API_KEY=

# Cron (Vercel u otro scheduler): Bearer token para POST /api/cron/*
# Si no se define, en desarrollo los endpoints pueden ejecutarse sin cabecera (no recomendado en producción).
CRON_SECRET=

# Email del equipo (opcional, alertas / flujos internos)
# ADMIN_EMAIL=

# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
